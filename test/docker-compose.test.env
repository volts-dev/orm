# Phase 0 baseline 测试环境变量样板
# 用法：source test/docker-compose.test.env && go test ./...
# 测试代码（test/orm_test.go）已支持以下变量

# MySQL（对应 docker-compose.test.yml）
export MYSQL_TEST_HOST=127.0.0.1:33306
export MYSQL_TEST_USER=root
export MYSQL_TEST_PASS=test

# PostgreSQL（对应 docker-compose.test.yml）
export POSTGRES_TEST_HOST=127.0.0.1:54320
export POSTGRES_TEST_USER=postgres
export POSTGRES_TEST_PASS=test

# SQLite 走 file mode，不需要环境变量；test/orm_test.go 默认使用 test.db
